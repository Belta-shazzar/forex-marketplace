# User Service
USER_SERVICE_PORT=3001
USER_SERVICE_JWT_SECRET=your-secret-key-change-in-production

# Wallet Service
WALLET_SERVICE_PORT=3002
WALLET_SERVICE_URL=http://localhost:3002/api

# Rate Service
RATE_SERVICE_PORT=3003
RATE_SERVICE_GRPC_PORT=5001
RATE_SERVICE_URL=http://localhost:3003/api

# Transaction Service
TRANSACTION_SERVICE_PORT=3004
TRANSACTION_SERVICE_URL=http://localhost:3004/api

# Database
MONGODB_URI=mongodb://admin:admin123@localhost:27017/forex-dev-db
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123

# External APIs
EXCHANGE_RATE_API_KEY=your-api-key-here
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# Node Environment
NODE_ENV=development
